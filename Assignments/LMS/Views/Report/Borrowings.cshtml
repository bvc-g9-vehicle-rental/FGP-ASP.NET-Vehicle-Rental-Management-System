@model BorrowingReportFilter
@{
    ViewData["Title"] = "Borrowing History Report";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📋 Borrowing History Report</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Reports</a>
</div>

<div class="card mb-4">
    <div class="card-header bg-dark text-white fw-semibold">Filter Options</div>
    <div class="card-body">
        <form asp-action="Borrowings" method="post">
            <div class="row g-3">
                <div class="col-md-2">
                    <label asp-for="FromDate" class="form-label fw-semibold"></label>
                    <input asp-for="FromDate" class="form-control" type="date" />
                </div>
                <div class="col-md-2">
                    <label asp-for="ToDate" class="form-label fw-semibold"></label>
                    <input asp-for="ToDate" class="form-control" type="date" />
                </div>
                <div class="col-md-2">
                    <label asp-for="Status" class="form-label fw-semibold"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="all">All</option>
                        <option value="active">Active</option>
                        <option value="returned">Returned</option>
                        <option value="overdue">Overdue</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="ReaderId" class="form-label fw-semibold"></label>
                    <select asp-for="ReaderId" asp-items="ViewBag.ReaderItems" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="BookId" class="form-label fw-semibold"></label>
                    <select asp-for="BookId" asp-items="ViewBag.BookItems" class="form-select"></select>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Generate Report</button>
                <a asp-action="Borrowings" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<p class="text-muted">Use the filters above and click <strong>Generate Report</strong> to see results.</p>
