@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <div style="font-size:2rem">📖</div>
            <div class="fs-2 fw-bold text-primary">@ViewBag.TotalBooks</div>
            <div class="text-muted small">Total Books</div>
            <a asp-controller="Book" asp-action="Index" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <div style="font-size:2rem">👥</div>
            <div class="fs-2 fw-bold text-success">@ViewBag.TotalReaders</div>
            <div class="text-muted small">Registered Readers</div>
            <a asp-controller="Reader" asp-action="Index" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <div style="font-size:2rem">🔄</div>
            <div class="fs-2 fw-bold text-warning">@ViewBag.ActiveBorrowings</div>
            <div class="text-muted small">Active Borrowings</div>
            <a asp-controller="Borrowing" asp-action="Index" class="stretched-link"></a>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>⚠️ Overdue Borrowings</span>
                <a asp-controller="Borrowing" asp-action="Index" asp-route-searchString="Overdue"
                   class="btn btn-sm btn-outline-warning">View all</a>
            </div>
            <div class="card-body p-0">
                @if (ViewBag.OverdueBorrowings is IEnumerable<Assignment4.Models.Borrowing> overdue && overdue.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Book</th><th>Reader</th><th>Due Date</th><th>Days Late</th></tr></thead>
                        <tbody>
                            @foreach (var b in overdue)
                            {
                                <tr>
                                    <td>@b.Book?.Title</td>
                                    <td>@b.Reader?.Name</td>
                                    <td class="text-danger">@b.DueDate.ToString("MMM d")</td>
                                    <td><span class="badge-overdue">@b.OverdueDays days</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">No overdue borrowings. 🎉</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">🔗 Quick Actions</div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-controller="Book" asp-action="Create" class="btn btn-outline-primary">+ Add New Book</a>
                <a asp-controller="Reader" asp-action="Create" class="btn btn-outline-success">+ Add New Reader</a>
                <a asp-controller="Borrowing" asp-action="Create" class="btn btn-outline-secondary">+ New Borrowing</a>
            </div>
        </div>
    </div>
</div>

