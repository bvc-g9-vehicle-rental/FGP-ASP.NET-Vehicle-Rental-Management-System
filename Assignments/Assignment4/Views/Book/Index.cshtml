@model IEnumerable<Assignment4.Models.Book>
@{
    ViewData["Title"] = "Books";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>📖 All Books</span>
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Add Book</a>
    </div>
    <div class="card-body">
        <!-- Search Bar -->
        <form asp-action="Index" method="get" class="mb-3">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                       class="form-control" placeholder="Search by title, author, ISBN or genre..." />
                <button class="btn btn-outline-primary" type="submit">🔍 Search</button>
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">✕ Clear</a>
                }
            </div>
        </form>

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <text>No books match "<strong>@ViewData["CurrentFilter"]</strong>". <a asp-action="Index">Show all</a>.</text>
                }
                else
                {
                    <text>No books found. <a asp-action="Create">Add the first one</a>.</text>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Author</th>
                            <th>Genre</th>
                            <th>ISBN</th>
                            <th>Year</th>
                            <th>Copies</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var book in Model)
                        {
                            <tr>
                                <td class="text-muted">@book.Id</td>
                                <td><strong>@book.Title</strong></td>
                                <td>@book.Author</td>
                                <td><span class="badge bg-secondary">@(book.Genre ?? "—")</span></td>
                                <td><code>@(book.ISBN ?? "—")</code></td>
                                <td>@(book.PublishedYear?.ToString() ?? "—")</td>
                                <td>@book.AvailableCopies / @book.TotalCopies</td>
                                <td>
                                    @if (book.IsAvailable)
                                    {
                                        <span class="badge-available">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge-unavailable">Fully Borrowed</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                    <a asp-action="Edit"    asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <a asp-action="Delete"  asp-route-id="@book.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="text-muted small mt-2">@Model.Count() book(s) found</div>
        }
    </div>
</div>
