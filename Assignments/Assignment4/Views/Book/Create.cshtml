@model Assignment4.Models.Book
@{
    ViewData["Title"] = "Add Book";
}

<div class="card" style="max-width:600px">
    <div class="card-header">📖 Add New Book</div>
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="Book title" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Author" class="form-label"></label>
                <input asp-for="Author" class="form-control" placeholder="Author name" />
                <span asp-validation-for="Author" class="text-danger small"></span>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label asp-for="ISBN" class="form-label"></label>
                    <input asp-for="ISBN" class="form-control" placeholder="e.g. 9780743273565" />
                    <span asp-validation-for="ISBN" class="text-danger small"></span>
                </div>
                <div class="col">
                    <label asp-for="Genre" class="form-label"></label>
                    <input asp-for="Genre" class="form-control" placeholder="e.g. Fiction" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label asp-for="PublishedYear" class="form-label"></label>
                    <input asp-for="PublishedYear" class="form-control" type="number" placeholder="e.g. 1984" />
                </div>
                <div class="col">
                    <label asp-for="TotalCopies" class="form-label"></label>
                    <input asp-for="TotalCopies" class="form-control" type="number" min="1" />
                    <span asp-validation-for="TotalCopies" class="text-danger small"></span>
                </div>
                <div class="col">
                    <label asp-for="AvailableCopies" class="form-label"></label>
                    <input asp-for="AvailableCopies" class="form-control" type="number" min="0" />
                    <span asp-validation-for="AvailableCopies" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Book</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
