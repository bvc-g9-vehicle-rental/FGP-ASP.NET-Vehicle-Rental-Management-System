@model Assignment4.Models.Borrowing
@{
    ViewData["Title"] = "Edit Borrowing";
}

<div class="card" style="max-width:500px">
    <div class="card-header">✏️ Edit Borrowing</div>
    <div class="card-body">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="BookId" class="form-label">Book</label>
                <select asp-for="BookId" asp-items="ViewBag.BookId" class="form-select"></select>
                <span asp-validation-for="BookId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ReaderId" class="form-label">Reader</label>
                <select asp-for="ReaderId" asp-items="ViewBag.ReaderId" class="form-select"></select>
                <span asp-validation-for="ReaderId" class="text-danger small"></span>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label asp-for="BorrowDate" class="form-label"></label>
                    <input asp-for="BorrowDate" class="form-control" type="date" />
                </div>
                <div class="col">
                    <label asp-for="DueDate" class="form-label"></label>
                    <input asp-for="DueDate" class="form-control" type="date" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label asp-for="ReturnDate" class="form-label"></label>
                    <input asp-for="ReturnDate" class="form-control" type="date" />
                </div>
                <div class="col">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Returned">Returned</option>
                        <option value="Overdue">Overdue</option>
                    </select>
                </div>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsReturned" class="form-check-input" type="checkbox" />
                <label asp-for="IsReturned" class="form-check-label">Mark as returned</label>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
