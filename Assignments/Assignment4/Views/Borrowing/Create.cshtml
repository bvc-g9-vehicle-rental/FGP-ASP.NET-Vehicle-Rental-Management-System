@model Assignment4.Models.Borrowing
@{
    ViewData["Title"] = "New Borrowing";
}

<div class="card" style="max-width:500px">
    <div class="card-header">🔄 New Borrowing</div>
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="BookId" class="form-label">Book</label>
                <select asp-for="BookId" asp-items="ViewBag.BookId" class="form-select">
                    <option value="">— Select a book —</option>
                </select>
                <span asp-validation-for="BookId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ReaderId" class="form-label">Reader</label>
                <select asp-for="ReaderId" asp-items="ViewBag.ReaderId" class="form-select">
                    <option value="">— Select a reader —</option>
                </select>
                <span asp-validation-for="ReaderId" class="text-danger small"></span>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label asp-for="BorrowDate" class="form-label"></label>
                    <input asp-for="BorrowDate" class="form-control" type="date" />
                    <span asp-validation-for="BorrowDate" class="text-danger small"></span>
                </div>
                <div class="col">
                    <label asp-for="DueDate" class="form-label"></label>
                    <input asp-for="DueDate" class="form-control" type="date" />
                    <span asp-validation-for="DueDate" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional notes..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-secondary">Create Borrowing</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
