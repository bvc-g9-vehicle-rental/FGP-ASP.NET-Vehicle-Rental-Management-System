@model Assignment4.Models.Reader
@{
    ViewData["Title"] = Model.Name;
}

<div class="card" style="max-width:700px">
    <div class="card-header">👤 @Model.Name</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3 form-label">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3 form-label">Phone</dt>
            <dd class="col-sm-9">@(Model.Phone ?? "—")</dd>

            <dt class="col-sm-3 form-label">Member Since</dt>
            <dd class="col-sm-9">@Model.MemberSince.ToString("MMMM d, yyyy")</dd>
        </dl>

        @if (Model.Borrowings.Any())
        {
            <h6 class="mt-4 mb-2">Borrowing History</h6>
            <table class="table table-sm table-bordered">
                <thead><tr><th>Book</th><th>Borrowed</th><th>Due</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var b in Model.Borrowings.OrderByDescending(x => x.BorrowDate))
                    {
                        <tr>
                            <td>@b.Book?.Title</td>
                            <td>@b.BorrowDate.ToString("MMM d, yyyy")</td>
                            <td>@b.DueDate.ToString("MMM d, yyyy")</td>
                            <td>
                                @{
                                    var cls = b.Status switch { "Overdue" => "badge-overdue", "Returned" => "badge-returned", _ => "badge-active" };
                                }
                                <span class="@cls">@b.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted mt-3">No borrowing history yet.</p>
        }
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
    </div>
</div>
