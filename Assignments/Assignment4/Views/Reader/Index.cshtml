@model IEnumerable<Assignment4.Models.Reader>
@{
    ViewData["Title"] = "Readers";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>👥 All Readers</span>
        <a asp-action="Create" class="btn btn-success btn-sm">+ Add Reader</a>
    </div>
    <div class="card-body">
        <!-- Search Bar -->
        <form asp-action="Index" method="get" class="mb-3">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                       class="form-control" placeholder="Search by name, email or phone..." />
                <button class="btn btn-outline-success" type="submit">🔍 Search</button>
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">✕ Clear</a>
                }
            </div>
        </form>

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <text>No readers match "<strong>@ViewData["CurrentFilter"]</strong>". <a asp-action="Index">Show all</a>.</text>
                }
                else
                {
                    <text>No readers found. <a asp-action="Create">Add the first one</a>.</text>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Member Since</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reader in Model)
                        {
                            <tr>
                                <td class="text-muted">@reader.Id</td>
                                <td><strong>@reader.Name</strong></td>
                                <td>@reader.Email</td>
                                <td>@(reader.Phone ?? "—")</td>
                                <td>@reader.MemberSince.ToString("MMM d, yyyy")</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@reader.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                    <a asp-action="Edit"    asp-route-id="@reader.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <a asp-action="Delete"  asp-route-id="@reader.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="text-muted small mt-2">@Model.Count() reader(s) found</div>
        }
    </div>
</div>
