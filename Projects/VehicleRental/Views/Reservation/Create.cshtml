@model VehicleRental.Models.Reservation
@{ ViewData["Title"] = "New Reservation"; }

<h2 class="mb-4">New Reservation</h2>

<div class="card shadow-sm" style="max-width:550px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="CustomerId" class="form-label fw-semibold">Customer</label>
                <select asp-for="CustomerId" asp-items="@(ViewBag.Customers as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)"
                        class="form-select">
                    <option value="">— Select Customer —</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="VehicleId" class="form-label fw-semibold">Vehicle (available only)</label>
                <select asp-for="VehicleId" asp-items="@(ViewBag.Vehicles as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)"
                        class="form-select">
                    <option value="">— Select Vehicle —</option>
                </select>
                <span asp-validation-for="VehicleId" class="text-danger small"></span>
            </div>

            <div class="row mb-3">
                <div class="col">
                    <label asp-for="StartDate" class="form-label fw-semibold"></label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>
                <div class="col">
                    <label asp-for="EndDate" class="form-label fw-semibold"></label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                    <span asp-validation-for="EndDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Notes" class="form-label fw-semibold"></label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Create Reservation</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<!-- Leaflet Pickup Location Map -->
<div class="card shadow-sm mt-4" style="max-width:550px">
    <div class="card-header bg-dark text-white">
        📍 Pickup Location <span class="text-white-50 fw-normal small">(optional — click map to pin)</span>
    </div>
    <div class="card-body p-2">
        <div id="pickup-info" class="text-muted small px-1 mb-2">Click anywhere on the map to set a pickup location.</div>
        <div id="pickup-map" style="height:280px; border-radius:6px;"></div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Initialize map centred on Calgary, AB
        var map = L.map('pickup-map').setView([51.0447, -114.0719], 11);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 18,
            attribution: '&copy; <a href="https://openstreetmap.org">OpenStreetMap</a> contributors'
        }).addTo(map);

        var marker = null;

        map.on('click', function (e) {
            var lat = e.latlng.lat.toFixed(5);
            var lng = e.latlng.lng.toFixed(5);

            document.getElementById('pickup-info').innerHTML =
                '📍 <strong>Pickup set:</strong> ' + lat + ', ' + lng +
                ' &nbsp;<span class="text-muted">(saved with reservation notes)</span>';

            if (marker) {
                marker.setLatLng(e.latlng);
            } else {
                marker = L.marker(e.latlng).addTo(map);
            }

            // Append coordinates to the Notes field (removing any previous location tag)
            var notesEl = document.querySelector('textarea[name="Notes"]');
            var cleaned = notesEl.value.replace(/\s*\[Pickup:[^\]]*\]/g, '').trim();
            notesEl.value = cleaned ? cleaned + '\n[Pickup: ' + lat + ',' + lng + ']'
                                    : '[Pickup: ' + lat + ',' + lng + ']';
        });
    </script>
}
