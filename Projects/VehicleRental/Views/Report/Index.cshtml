@{ ViewData["Title"] = "Reports"; }

<h2 class="mb-4">Reports</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-semibold" for="startDate">Start Date</label>
                <input id="startDate" name="startDate" type="date" value="@ViewBag.StartDate" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold" for="endDate">End Date</label>
                <input id="endDate" name="endDate" type="date" value="@ViewBag.EndDate" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold" for="vehicleType">Vehicle Type</label>
                <select id="vehicleType" name="vehicleType" class="form-select" asp-items="@(ViewBag.VehicleTypes as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)">
                    <option value="">All Types</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-dark">Apply Filters</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">

    <!-- Summary Cards -->
    <div class="col-md-4">
        <div class="card shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1 fw-bold text-success">$@(((decimal)ViewBag.TotalRevenue).ToString("N2"))</div>
                <div class="text-muted">Total Revenue (Paid)</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1 fw-bold text-primary">@ViewBag.TotalReservations</div>
                <div class="text-muted">Total Reservations</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm text-center h-100">
            <div class="card-body">
                <div class="fs-1 fw-bold text-warning">@(((double)ViewBag.FleetUtilization).ToString("F1"))%</div>
                <div class="text-muted">Fleet Utilization</div>
            </div>
        </div>
    </div>

    <!-- Reservations by Status -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-dark text-white">Reservations by Status</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light"><tr><th>Status</th><th>Count</th></tr></thead>
                    <tbody>
                        @foreach (var item in (dynamic)ViewBag.ReservationsByStatus)
                        {
                            <tr><td>@item.Status</td><td>@item.Count</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Revenue by Vehicle Type -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-dark text-white">Revenue by Vehicle Type</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light"><tr><th>Type</th><th>Revenue</th></tr></thead>
                    <tbody>
                        @foreach (var item in (dynamic)ViewBag.RevenueByType)
                        {
                            <tr><td>@item.Type</td><td>$@(((decimal)item.Revenue).ToString("N2"))</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Top Customers -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">Top Customers</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light"><tr><th>Customer</th><th>Total Reservations</th></tr></thead>
                    <tbody>
                        @foreach (var item in (dynamic)ViewBag.TopCustomers)
                        {
                            <tr><td>@item.Customer</td><td>@item.TotalTrips</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
